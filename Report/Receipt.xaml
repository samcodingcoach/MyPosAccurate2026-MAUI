<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MyPosAccurate2026.Report.Receipt"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit" NavigationPage.HasNavigationBar="False"
             BackgroundColor="#f8fafa"
             Title="Receipt">
    
    <Grid RowDefinitions="Auto, *, Auto">
        <Border Grid.Row="0" Padding="20,15" StrokeShape="RoundRectangle 10" Margin="10" Stroke="Transparent" StrokeThickness="0.5" BackgroundColor="White">
            <Border.Shadow>
                <Shadow Brush="#000000" Opacity="0.10" Radius="12" Offset="0,-3" />
            </Border.Shadow>
            <toolkit:Expander IsExpanded="False">
                <toolkit:Expander.Header>
                    <StackLayout Orientation="Horizontal">
                        <Label Text="Laporan Penerimaan Kasir" FontSize="20" TextColor="#444" VerticalTextAlignment="Center" FontAttributes="Bold"></Label>
                        <Image Source="chevron100.png" HeightRequest="24" HorizontalOptions="EndAndExpand"></Image>
                    </StackLayout>
                </toolkit:Expander.Header>

                <Grid ColumnDefinitions="*,*" Grid.Row="0" RowDefinitions="Auto,Auto, Auto" ColumnSpacing="10" Margin="0,10">
                    <Label Text="Berdasarkan tanggal" Margin="0,0,0,5" TextColor="Grey"></Label>
                    <Border Grid.Column="0" Grid.Row="1" Padding="10,0" StrokeShape="RoundRectangle 10"  Stroke="#CCCCCC" StrokeThickness="0.5" BackgroundColor="White">
                        <!--buat ini selalu tanggal 1 diawal bulan sekarang-->
                        <DatePicker FontSize="Large" x:Name="DP_startdate"/>
                    </Border>
                    <Border Grid.Column="1" Grid.Row="1"  Padding="10,0" StrokeShape="RoundRectangle 10"  Stroke="#CCCCCC" StrokeThickness="0.5" BackgroundColor="White">
                        <DatePicker FontSize="Large" x:Name="DP_enddate" />
                    </Border>

                    <StackLayout Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="2" Margin="0,15,0,0">
                        <Label Text="Berdasarkan Kasir" Margin="0,0,0,5" TextColor="Grey"></Label>
                        <Border Grid.Column="1" Grid.Row="1"  Padding="10,0" StrokeShape="RoundRectangle 10"  Stroke="#CCCCCC" StrokeThickness="0.5" BackgroundColor="White">
                            <StackLayout Orientation="Horizontal">
                                
                                <Picker x:Name="PickerNamaKasir" Title="Pilih Nama Kasir" ItemDisplayBinding="{Binding DisplayName}" HorizontalOptions="FillAndExpand"></Picker>
                                <Image Source="chevron100.png" HeightRequest="24" HorizontalOptions="EndAndExpand"></Image>
                            </StackLayout>
                        </Border>

                        <Button Text="GENERATE REPORT" CharacterSpacing="4" 
                                BackgroundColor="DarkCyan"
                                FontAttributes="Bold" Margin="0,20,0,0"
                                x:Name="BtnGenerate" Clicked="BtnGenerate_Clicked"></Button>
                    </StackLayout>
                </Grid>

            </toolkit:Expander>
        </Border>
        
        <!--row 2 desain report-->
        <Grid Grid.Row="1" Margin="10,0,10,10">
            <!--Placeholder ketika belum ada data-->
            <Label x:Name="LblEmptyReport"
                   Text="Pilih rentang tanggal lalu tekan GENERATE REPORT."
                   FontSize="13" TextColor="#999"
                   HorizontalOptions="Center" VerticalOptions="Start"
                   HorizontalTextAlignment="Center" Margin="0,30,0,0"/>

            <Border x:Name="ReportBorder" IsVisible="False"
                    Stroke="#333" StrokeThickness="1"
                    StrokeShape="Rectangle" BackgroundColor="White">
                <CollectionView x:Name="ReportCollection" IsGrouped="True">

                    <!--Kop usaha + Judul + periode + header kolom-->
                    <CollectionView.Header>
                        <VerticalStackLayout Padding="12,10" Spacing="2">
                            <!--Kop pelaporan (info usaha)-->
                            <Label Text="{Binding CompanyName}" IsVisible="{Binding HasCompany}"
                                   FontSize="18" FontAttributes="Bold" TextColor="#222"
                                   HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                            <Label Text="{Binding CompanyAddress}" IsVisible="{Binding HasCompany}"
                                   FontSize="12" TextColor="#666"
                                   HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                            <Label Text="{Binding CompanyRegion}" IsVisible="{Binding HasCompany}"
                                   FontSize="12" TextColor="#666"
                                   HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                            <Label Text="{Binding CompanyContact}" IsVisible="{Binding HasCompany}"
                                   FontSize="12" TextColor="#666"
                                   HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                            <BoxView HeightRequest="1" Color="#CCC" Margin="0,6"
                                     IsVisible="{Binding HasCompany}"/>

                            <Label Text="Laporan Penerimaan Berdasarkan Kasir"
                                   FontSize="17" FontAttributes="Bold" TextColor="#333"
                                   HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                            <Label Text="{Binding Periode}"
                                   FontAttributes="Italic" FontSize="13" TextColor="#666"
                                   HorizontalOptions="Center" HorizontalTextAlignment="Center"
                                   Margin="0,0,0,8"/>
                            <Grid ColumnDefinitions="*,70,120" ColumnSpacing="8">
                                <Label Grid.Column="0" Text="Metode Pembayaran" FontAttributes="Bold" TextColor="#222"/>
                                <Label Grid.Column="1" Text="Jumlah" FontAttributes="Bold" TextColor="#222" HorizontalTextAlignment="End"/>
                                <Label Grid.Column="2" Text="Total" FontAttributes="Bold" TextColor="#222" HorizontalTextAlignment="End"/>
                            </Grid>
                            <BoxView HeightRequest="1" Color="#333" Margin="0,4,0,0"/>
                        </VerticalStackLayout>
                    </CollectionView.Header>

                    <!--Sub-header per tanggal-->
                    <CollectionView.GroupHeaderTemplate>
                        <DataTemplate>
                            <Label Text="{Binding DateLabel}" FontSize="13" TextColor="#333"
                                   Padding="12,8,12,2"/>
                        </DataTemplate>
                    </CollectionView.GroupHeaderTemplate>

                    <!--Baris metode pembayaran-->
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="*,70,120" ColumnSpacing="8" Padding="12,1">
                                <Label Grid.Column="0" Text="{Binding DisplayMethod}" FontSize="13" TextColor="#222"/>
                                <Label Grid.Column="1" Text="{Binding DisplayCount}" FontSize="13" TextColor="#222" HorizontalTextAlignment="End"/>
                                <Label Grid.Column="2" Text="{Binding DisplayAmount}" FontSize="13" TextColor="#222" HorizontalTextAlignment="End"/>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>

                    <!--Total per tanggal-->
                    <CollectionView.GroupFooterTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="*,70,120" ColumnSpacing="8" Padding="12,6,12,10">
                                <Label Grid.Column="0" Text="Total" FontSize="13" TextColor="#222"/>
                                <Label Grid.Column="1" Text="{Binding DisplayCount}" FontSize="13" TextColor="#222" HorizontalTextAlignment="End"/>
                                <Label Grid.Column="2" Text="{Binding DisplayTotal}" FontSize="13" TextColor="#222" HorizontalTextAlignment="End"/>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.GroupFooterTemplate>

                    <!--Ringkasan + grand total + nama kasir-->
                    <CollectionView.Footer>
                        <VerticalStackLayout Padding="12,4,12,10" Spacing="2">
                            <BoxView HeightRequest="1" Color="#333" Margin="0,0,0,4"/>
                            <Label Text="Ringkasan" FontAttributes="Bold" FontSize="13" TextColor="#222"/>

                            <Grid ColumnDefinitions="*,120" ColumnSpacing="8">
                                <Label Grid.Column="0" Text="Jumlah Transaksi" FontSize="13" TextColor="#222"/>
                                <Label Grid.Column="1" Text="{Binding JumlahTransaksi}" FontSize="13" TextColor="#222" HorizontalTextAlignment="End"/>
                            </Grid>

                            <!--Total per metode-->
                            <VerticalStackLayout BindableLayout.ItemsSource="{Binding Methods}" Spacing="0">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnDefinitions="*,120" ColumnSpacing="8">
                                            <Label Grid.Column="0" Text="{Binding MethodName}" FontSize="13" TextColor="#222"/>
                                            <Label Grid.Column="1" Text="{Binding DisplayAmount}" FontSize="13" TextColor="#222" HorizontalTextAlignment="End"/>
                                        </Grid>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>

                            <!--Total keseluruhan (latar abu-abu)-->
                            <Grid ColumnDefinitions="*,120" ColumnSpacing="8" BackgroundColor="#E8E8E8" Padding="0,4" Margin="0,6,0,0">
                                <Label Grid.Column="0" Text="Total" FontAttributes="Bold" FontSize="13" TextColor="#222" HorizontalTextAlignment="Center"/>
                                <Label Grid.Column="1" Text="{Binding GrandTotal}" FontAttributes="Bold" FontSize="13" TextColor="#222" HorizontalTextAlignment="End"/>
                            </Grid>

                            <Grid ColumnDefinitions="*,120" ColumnSpacing="8" Padding="0,2">
                                <Label Grid.Column="0" Text="Nama Kasir" FontSize="13" TextColor="#222" HorizontalTextAlignment="Center"/>
                                <Label Grid.Column="1" Text="{Binding NamaKasir}" FontAttributes="Bold" FontSize="13" TextColor="#222" HorizontalTextAlignment="End"/>
                            </Grid>
                        </VerticalStackLayout>
                    </CollectionView.Footer>
                </CollectionView>
            </Border>
        </Grid>

        <!--Aksi: unduh PDF & kirim WhatsApp-->
        <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="10" Padding="10,5,10,10">
            <Button x:Name="BtnDownloadPdf" Grid.Column="0" Text="DOWNLOAD PDF"
                    CharacterSpacing="2" FontAttributes="Bold" BackgroundColor="#444"
                    Clicked="BtnDownloadPdf_Clicked"/>
            <Button x:Name="BtnWhatsApp" Grid.Column="1" Text="KIRIM WHATSAPP"
                    CharacterSpacing="2" FontAttributes="Bold" BackgroundColor="#25D366"
                    Clicked="BtnWhatsApp_Clicked"/>
        </Grid>
    </Grid>
</ContentPage>