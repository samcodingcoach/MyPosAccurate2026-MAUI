<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MyPosAccurate2026.Stok.SO_ResultAdd_Detail" NavigationPage.HasNavigationBar="False"
             xmlns:zxing="clr-namespace:ZXing.Net.Maui.Controls;assembly=ZXing.Net.MAUI.Controls"
             Title="SO_ResultAdd_Detail">
    <Grid RowDefinitions="*,Auto" RowSpacing="0" ColumnDefinitions="*" ColumnSpacing="10" Padding="0">

        <!--scan area : -ikutin desain SCANQR.xaml -->
        <Grid Grid.Row="0">
            <zxing:CameraBarcodeReaderView x:Name="CameraScanner" BarcodesDetected="CameraScanner_BarcodesDetected" />

            <!--Bingkai pemindaian-->
            <Border WidthRequest="240" HeightRequest="240" InputTransparent="True"
                    StrokeShape="RoundRectangle 20" Stroke="White" StrokeThickness="3"
                    BackgroundColor="Transparent" HorizontalOptions="Center" VerticalOptions="Center" />

            <Label Text="Arahkan kamera ke barcode / QR code produk" InputTransparent="True"
                   TextColor="White" FontAttributes="Bold" BackgroundColor="#80000000" Padding="16,8"
                   HorizontalOptions="Center" VerticalOptions="Start" Margin="0,30,0,0" />

            <Label x:Name="LblScanStatus" Text="" IsVisible="False" InputTransparent="True"
                   TextColor="White" FontAttributes="Bold" Padding="16,8"
                   HorizontalOptions="Center" VerticalOptions="End" Margin="0,0,0,30" />

            <ActivityIndicator x:Name="LoadingIndicator" IsRunning="False" IsVisible="False"
                               Color="White" HorizontalOptions="Center" VerticalOptions="Center" />
        </Grid>
        
        
        <!--input data-->

        <Border Grid.Row="1" Padding="20" StrokeShape="RoundRectangle 20,20,0,0"  Stroke="Transparent" 
                StrokeThickness="0.5" BackgroundColor="White">
            <Border.Shadow>
                <Shadow Brush="#000000" Opacity="0.10" Radius="5" Offset="0,-1" />
            </Border.Shadow>

            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,*,Auto" ColumnSpacing="10" RowSpacing="10">
                <Image Source="pp100.jpg" HeightRequest="60" Grid.Column="0" VerticalOptions="Start" x:Name="itemImage"></Image>
                <StackLayout Grid.Column="1" Spacing="2">
                    <Label Text="NAMA BARANG YANG DI CATAT STOK OPNAMENYA GUYS" TextColor="#444" x:Name="itemNamaBarang"
                           FontAttributes="Bold" MaxLines="2" LineBreakMode="TailTruncation"
                           TextTransform="Uppercase"></Label>
                    <Label Text="No. 12345567890" TextColor="Grey" FontSize="Caption" x:Name="itemNo"></Label>

                    <Border Padding="15,0" Margin="0,5,0,0" StrokeShape="RoundRectangle 2" Stroke="Transparent" StrokeThickness="0.5" BackgroundColor="WhiteSmoke" >
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Label Text="Kuantitas Pemeriksaan" FontAttributes="Bold" Grid.Column="0" 
                                   VerticalTextAlignment="Center" TextColor="Grey"></Label>
                            <Entry Text="0" TextColor="Red" FontSize="28" HorizontalTextAlignment="End" Keyboard="Numeric" Grid.Column="1"></Entry>
                            <Label Text="UNIT" Grid.Column="2" VerticalTextAlignment="Center" FontAttributes="Bold" Opacity="0.2"></Label>
                        </Grid>
                    </Border>
                </StackLayout>

                <!--serial input jika ada -->
                <Grid x:Name="ViewSerialInput" IsVisible="False"  Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"  
                      ColumnDefinitions="*,Auto" RowDefinitions="Auto,*" ColumnSpacing="10">
                      
                    <Border Padding="15,0" Grid.Column="0" StrokeShape="RoundRectangle 5" Stroke="LightGrey" StrokeThickness="0.5" BackgroundColor="Transparent" >
                        <Entry Placeholder="Nomor Serial" PlaceholderColor="LightGrey"></Entry>
                    </Border>

                    <Border Padding="12" Grid.Column="1"  StrokeShape="RoundRectangle 5" Stroke="LightGrey" 
                            StrokeThickness="0" BackgroundColor="LightSkyBlue" >
                        <Image Source="add24.png" HeightRequest="15"></Image>
                    </Border>
                    
                    <!--Serial Data-->
                    <CollectionView x:Name="CV_Serial" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,15,0,0">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="10" RowDefinitions="Auto,Auto" RowSpacing="10" Margin="0,0,0,10">
                                    <!-- Bullet or Number -->
                                    <Label Text="•" Grid.Column="0" VerticalTextAlignment="Center" TextColor="Grey" FontAttributes="Bold"></Label>
                                    
                                    <Label Text="{Binding serialNumber.number}" Grid.Column="1" VerticalTextAlignment="Center"></Label>
                                    <Label Text="{Binding quantity, StringFormat='{0} UNIT'}" Grid.Column="2" VerticalTextAlignment="Center"></Label>
                                    
                                    <Image Source="nonactive1.png" HeightRequest="20" Grid.Column="3">
                                        <Image.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="BtnDeleteSerial_Tapped" />
                                        </Image.GestureRecognizers>
                                    </Image>

                                    <Line X2="360" Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="4" Stroke="#CFCFCF" StrokeThickness="1.4" StrokeDashArray="3,3" HorizontalOptions="Fill" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Grid>

                <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" ColumnDefinitions="*,*" ColumnSpacing="10">
                    <Button Text="INPUT NO.SERIAL" IsEnabled="False" Grid.Column="0" x:Name="BtnViewSerial" Clicked="BtnViewSerial_Clicked"  TextColor="DarkCyan" FontAttributes="Bold"  BackgroundColor="Transparent" BorderColor="DarkCyan" BorderWidth="0.5"></Button>
                    <Button Text="SIMPAN OPNAME" IsEnabled="False" Grid.Column="1" x:Name="BtnSimpan" Clicked="BtnSimpan_Clicked"  FontAttributes="Bold"  BackgroundColor="DarkCyan" BorderWidth="0.5"></Button>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</ContentPage>