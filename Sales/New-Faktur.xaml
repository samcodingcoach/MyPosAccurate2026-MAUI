<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MyPosAccurate2026.Sales.New_Faktur"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#d2dae2" 
            >
    <Grid RowDefinitions="Auto,*,Auto,Auto" RowSpacing="0" ColumnDefinitions="*" ColumnSpacing="10" Padding="0,0">
        <!--row 0-->
        <Border Grid.Row="0" Padding="20,10,20,0" StrokeShape="RoundRectangle 0,0,20,20"  Stroke="Transparent" StrokeThickness="0.5" BackgroundColor="White">
            <toolkit:Expander IsExpanded="True">
                <toolkit:Expander.Header>
                    <StackLayout Orientation="Horizontal">
                        <Label Text="NEW FAKTUR JUAL" HorizontalOptions="FillAndExpand" FontSize="Large" FontAttributes="Bold"  Padding="5"/>
                        <Image Source="chevron100.png" TranslationY="-3" HeightRequest="24"></Image>
                    </StackLayout>
                </toolkit:Expander.Header>

                <Grid ColumnDefinitions="*,*"  RowDefinitions="Auto,Auto,Auto"  RowSpacing="10"   ColumnSpacing="10"  Padding="0">
                    <StackLayout Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="2" Spacing="10">
                        <Border Padding="10,0" StrokeShape="RoundRectangle 10" Stroke="#CCCCCC" StrokeThickness="0.5" BackgroundColor="WhiteSmoke">
                            <!--cari api konsumen-->
                            <StackLayout Orientation="Horizontal">
                                <Picker x:Name="PickerKonsumen" HorizontalOptions="FillAndExpand" Title="Pilih Konsumen / Pelanggan"  ItemDisplayBinding="{Binding Text}" SelectedIndexChanged="OnKonsumenSelected" />
                                <Image Source="search32.png" HeightRequest="18" Opacity="0.5" IsVisible="True" x:Name="ImageSearchKonsumen"></Image>
                                <Image Source="cancel1.png" HeightRequest="18" IsVisible="False" x:Name="ImageCancelKonsumen">
                                    <Image.GestureRecognizers>
                                        <TapGestureRecognizer x:Name="TapCancelKonsumen" NumberOfTapsRequired="1" Tapped="TapCancelKonsumen_Tapped"></TapGestureRecognizer>
                                    </Image.GestureRecognizers>
                                </Image>
                                
                            </StackLayout>
                            <!--cari api konsumen-->
                        </Border>
                    </StackLayout>
                </Grid>
            </toolkit:Expander>
        </Border>
        
        <!--row 1 cari barang dan detail , Munculkan Sistem Dialog Pengiriman Visible On Off-->
        <Border Grid.Row="1" VerticalOptions="FillAndExpand" Padding="10" StrokeShape="RoundRectangle 10" Margin="10,5" 
                Stroke="Transparent" StrokeThickness="0.5" BackgroundColor="White">

            <Grid RowDefinitions="*, Auto">
                <!--ViewBarang Search-->
                <Grid Grid.Row="0" x:Name="ViewBarang" RowDefinitions="Auto, *" IsVisible="True">

                    <StackLayout Grid.Row="0" Orientation="Horizontal" Padding="5,0,5,10">
                        <Label Text="DETAIL BARANG" HorizontalOptions="FillAndExpand" FontSize="Large" FontAttributes="Bold"/>
                    </StackLayout>

                    <Grid Grid.Row="1" RowDefinitions="Auto, *" RowSpacing="10">

                        <Border Grid.Row="0"  StrokeShape="RoundRectangle 10" Stroke="#CCCCCC" StrokeThickness="0.5" 
                                BackgroundColor="WhiteSmoke">
                            <StackLayout>
                                <SearchBar Placeholder="Ketik Nama atau Kode Barang..." x:Name="SearchBar_Item" SearchIconColor="DarkCyan" TranslationX="-10" 
                                           TextChanged="SearchBar_Item_TextChanged" HorizontalOptions="FillAndExpand"/>

                                <Border x:Name="Border_AutoComplete" IsVisible="False" Padding="0" Margin="0, -10, 0, 10" StrokeShape="RoundRectangle 5" Stroke="#CCCCCC" StrokeThickness="1" BackgroundColor="White" MaximumHeightRequest="200">
                                    <Border.Shadow>
                                        <Shadow Brush="Black" Offset="0,2" Radius="5" Opacity="0.2" />
                                    </Border.Shadow>
                                    <!--Search result-->
                                    <CollectionView x:Name="List_AutoComplete" SelectionMode="Single" SelectionChanged="List_AutoComplete_SelectionChanged">
                                        <CollectionView.EmptyView>
                                            <StackLayout Padding="15">
                                                <Label Text="Tidak ada barang yang cocok." TextColor="Red" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center"/>
                                            </StackLayout>
                                        </CollectionView.EmptyView>

                                        <CollectionView.ItemTemplate>
                                            <DataTemplate>
                                                <StackLayout Padding="10" Orientation="Horizontal" BackgroundColor="White">
                                                    <StackLayout HorizontalOptions="FillAndExpand">
                                                        <Label Text="{Binding name}" FontAttributes="Bold" FontSize="14" TextColor="Black"/>
                                                        <Label Text="{Binding item_no}" FontSize="12" TextColor="Gray"/>
                                                    </StackLayout>
                                                    <StackLayout HorizontalOptions="End" VerticalOptions="Center">
                                                        <Label Text="{Binding balance, StringFormat='Stock: {0:N0}'}" FontSize="12" TextColor="{Binding StockColor}"/>
                                                    </StackLayout>
                                                </StackLayout>
                                            </DataTemplate>
                                        </CollectionView.ItemTemplate>
                                    </CollectionView>
                                </Border>
                            </StackLayout>
                        </Border>
                        <!--cart-->
                        <CollectionView Grid.Row="1" x:Name="CartContainer" Margin="0,10,0,0" VerticalOptions="FillAndExpand">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Vertical" ItemSpacing="10" />
                            </CollectionView.ItemsLayout>

                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="Auto, *" ColumnSpacing="15" Margin="0,0,0,10">

                                        <Image Source="{Binding DisplayImage}" Grid.Column="0" HeightRequest="75" WidthRequest="75" Aspect="AspectFill" VerticalOptions="Start"></Image>

                                        <StackLayout Grid.Column="1" Spacing="2">

                                            <Grid ColumnDefinitions="*, Auto">
                                                <Label Grid.Column="0" Text="{Binding itemName}" FontAttributes="Bold" TextColor="Black" FontSize="14" MaxLines="2" LineBreakMode="TailTruncation" VerticalOptions="Start" />
                                               
                                                <Image Source="delete1.png" HeightRequest="20" HorizontalOptions="EndAndExpand">
                                                    <Image.GestureRecognizers>
                                                        <TapGestureRecognizer Tapped="HapusCartItem_Tapped" />
                                                    </Image.GestureRecognizers>
                                                </Image>
                                                
                                            </Grid>

                                            <Label Text="{Binding ItemInfoDisplay}" TextColor="Black" FontSize="12" />

                                            <Label Text="{Binding PriceAndQtyDisplay}" TextColor="Black" FontSize="13" />

                                            <Label Text="{Binding SerialNumbersDisplay}" TextColor="Gray" FontSize="12" IsVisible="{Binding HasSerialNumbers}" />

                                            <Grid ColumnDefinitions="*, Auto" Margin="0,3,0,0">
                                                <Label Grid.Column="0" Text="{Binding TotalHargaLabel}" TextColor="Black" FontSize="13" VerticalOptions="Center" />
                                                <Label Grid.Column="1" Text="{Binding FormattedTotalPrice}" FontAttributes="Bold" TextColor="#4CAF50" FontSize="14" VerticalOptions="Center" HorizontalOptions="End" />
                                            </Grid>

                                            <BoxView HeightRequest="0.5" Margin="0,15,0,0" Color="#E0E0E0" HorizontalOptions="Fill" />

                                        </StackLayout>
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                    </Grid>
                </Grid>
                <!--Pengiriman ViewPengiriman-->
                <StackLayout Grid.Row="0" x:Name="ViewPengirim" IsVisible="False" Spacing="10">
                    <HorizontalStackLayout Spacing="10">
                        <Image Source="shipmentgrey100.png" HeightRequest="14"></Image>
                        <Label Text="Pengiriman dan Alamat" FontSize="16" FontAttributes="Bold" TextColor="Grey"></Label>
                    </HorizontalStackLayout>

                    <Border Padding="10,5" StrokeShape="RoundRectangle 10" Stroke="#CCCCCC" StrokeThickness="0.5" BackgroundColor="WhiteSmoke">
                        <StackLayout Orientation="Horizontal">
                            <Picker x:Name="PickerPengirim" HorizontalOptions="FillAndExpand" Title="Pilih Pengirim"
                                    SelectedIndexChanged="PickerPengirim_SelectedIndexChanged">
                                <Picker.Items>
                                    <x:String>Kurir Toko</x:String>
                                    <x:String>Ambil Sendiri</x:String>
                                </Picker.Items>
                            </Picker>
                            <Image Source="search32.png" HeightRequest="20" Opacity="0.5"></Image>
                        </StackLayout>
                    </Border>

                    <Border x:Name="BorderAlamat" IsVisible="False" Padding="10,5" StrokeShape="RoundRectangle 10" Stroke="#CCCCCC" StrokeThickness="0.5" BackgroundColor="WhiteSmoke" Margin="0,0,0,10">
                        <Editor x:Name="EntryAlamat" MinimumHeightRequest="100" AutoSize="TextChanges" Placeholder="Alamat Pengiriman"></Editor>
                    </Border>
                    <Button x:Name="B_CariAlamatMaps" IsVisible="False" Text="📍 Cari Alamat by Maps" Clicked="B_CariAlamatMaps_Clicked"
                            BackgroundColor="#0E6E6E" TextColor="White" CornerRadius="10" HeightRequest="44"
                            FontAttributes="Bold" Margin="0,0,0,10" />
                    <Border Padding="10,5" StrokeShape="RoundRectangle 10" Stroke="#CCCCCC" StrokeThickness="0.5" BackgroundColor="WhiteSmoke" Margin="0,0,0,10">
                        <StackLayout>
                            <Entry x:Name="EntryNoPO" VerticalTextAlignment="Start" Placeholder="Nomor PO (Opsional)"></Entry>

                            <Entry HeightRequest="120" x:Name="EntryKeterangan" VerticalTextAlignment="Start" Placeholder="Keterangan"></Entry>
                        </StackLayout>
                    </Border>
                    
                    
                </StackLayout>
                <!--Pajak ViewBiaya-->
                <StackLayout Grid.Row="0" x:Name="ViewBiaya" IsVisible="False" Spacing="10">
                    <HorizontalStackLayout Spacing="10">
                        <Image Source="propertiesgrey100.png" HeightRequest="14"></Image>
                        <Label Text="Biaya dan Pajak" FontSize="16" FontAttributes="Bold" TextColor="Grey"></Label>
                    </HorizontalStackLayout>

                    <Border Padding="10,5" StrokeShape="RoundRectangle 10" Stroke="#CCCCCC" StrokeThickness="0.5" BackgroundColor="WhiteSmoke">
                        <StackLayout Orientation="Horizontal">
                            <Picker x:Name="PickerBiaya" HorizontalOptions="FillAndExpand" Title="Pilih Biaya Lain" ItemDisplayBinding="{Binding DisplayName}">
                            </Picker>
                            <Image Source="search32.png" HeightRequest="20" Opacity="0.5"></Image>
                        </StackLayout>
                    </Border>

                    <StackLayout Spacing="10" Orientation="Horizontal">
                        <Border Padding="10,5" StrokeShape="RoundRectangle 10" HorizontalOptions="FillAndExpand" Stroke="#CCCCCC" StrokeThickness="0.5" BackgroundColor="WhiteSmoke">
                            <Entry x:Name="EntryHargaBiaya" Placeholder="Harga biaya Ex. 25000" Keyboard="Numeric" HorizontalOptions="FillAndExpand" TextChanged="EntryHargaBiaya_TextChanged"></Entry>
                        </Border>
                        <Button x:Name="BTambahBiaya" Text="Tambah" Clicked="BTambahBiaya_Clicked" BackgroundColor="DodgerBlue" FontAttributes="Bold" FontSize="16" HorizontalOptions="End"></Button>
                    </StackLayout>

                    <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="10" BackgroundColor="WhiteSmoke" Padding="10">
                        <Label Text="No." FontAttributes="Bold" Grid.Column="0" TextColor="Grey" VerticalTextAlignment="Center" HorizontalTextAlignment="Center"></Label>
                        <Label Text="Keterangan Biaya" FontAttributes="Bold" Grid.Column="1" TextColor="Grey" VerticalTextAlignment="Center" HorizontalTextAlignment="Start"></Label>
                        <Label Text="Nominal" FontAttributes="Bold" Grid.Column="2" TextColor="Grey" VerticalTextAlignment="Center" HorizontalTextAlignment="End"></Label>
                    </Grid>

                    <BoxView HeightRequest="1" Margin="10,5" Opacity="1" Color="WhiteSmoke" HorizontalOptions="Fill" />

                    <StackLayout x:Name="ListBiayaContainer" BackgroundColor="WhiteSmoke" Padding="10" Spacing="10">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="10">
                                    <Label Text="{Binding No}" FontAttributes="Bold" Grid.Column="0" TextColor="DodgerBlue" VerticalTextAlignment="Center" HorizontalTextAlignment="Center"></Label>
                                    <Label Text="{Binding Name}" FontAttributes="Bold" Grid.Column="1" TextColor="Grey" VerticalTextAlignment="Center" HorizontalTextAlignment="Start"></Label>
                                    <Label Text="{Binding FormattedNominal}" FontAttributes="Bold" Grid.Column="2" TextColor="Grey" VerticalTextAlignment="Center" HorizontalTextAlignment="End"></Label>
                                    <Label Text="Hapus" FontAttributes="Bold" Grid.Column="3" TextColor="OrangeRed" VerticalTextAlignment="Center" HorizontalTextAlignment="End">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="HapusBiaya_Tapped" />
                                        </Label.GestureRecognizers>
                                    </Label>
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </StackLayout>

                    <HorizontalStackLayout>
                        <CheckBox IsChecked="True" Color="DarkCyan" x:Name="CheckBoxPPN" CheckedChanged="CheckBoxPPN_CheckedChanged"></CheckBox>
                        <Label Text="Pajak 11/12" VerticalTextAlignment="Center" FontSize="15" TextColor="Grey"></Label>
                    </HorizontalStackLayout>
                </StackLayout>
                <!--Diskon ViewDiskon-->
                <StackLayout Grid.Row="0" x:Name="ViewDiskon" IsVisible="False" Spacing="10">
                    <HorizontalStackLayout Spacing="10">
                        <Image Source="diskon100.png" HeightRequest="14"></Image>
                        <Label Text="Diskon Akhir" FontSize="16" FontAttributes="Bold" TextColor="Grey"></Label>
                    </HorizontalStackLayout>

                    <Border Padding="10,5" StrokeShape="RoundRectangle 10" Stroke="#CCCCCC" StrokeThickness="0.5" BackgroundColor="WhiteSmoke">
                        <Entry Placeholder="Diskon Nominal Ex. 10.000" x:Name="EntryDiskonNominal" TextChanged="EntryDiskonNominal_TextChanged" Keyboard="Numeric"></Entry>
                    </Border>

                    <Border Padding="10,5" StrokeShape="RoundRectangle 10" Stroke="#CCCCCC" StrokeThickness="0.5" BackgroundColor="WhiteSmoke">
                        <Entry Placeholder="Diskon Persen Ex. 50%" x:Name="EntryDiskonPersen"></Entry>
                    </Border>

                    <HorizontalStackLayout Spacing="10">
                        <Button Text="Hapus" x:Name="BHapusDiskon" Clicked="BHapusDiskon_Clicked" BackgroundColor="OrangeRed" FontAttributes="Bold" FontSize="16" HorizontalOptions="End"></Button>
                        <Button Text="Tambah" x:Name="BTambahkanDiskon" Clicked="BTambahkanDiskon_Clicked" BackgroundColor="DodgerBlue" FontAttributes="Bold" FontSize="16" HorizontalOptions="End"></Button>
                    </HorizontalStackLayout>

                    <Label Text="" x:Name="KeteranganDiskon" TextColor="DeepPink"></Label>
                </StackLayout>
                
                <!--Close Button-->
                <Button Grid.Row="1" Text="Close" x:Name="BClose" IsVisible="False" Clicked="BClose_Clicked" HorizontalOptions="End" WidthRequest="60" BackgroundColor="Transparent" TextColor="Grey" BorderColor="Grey" BorderWidth="1" ></Button>

            </Grid>
        </Border>

        <!--row 2 subtotal pajak diskon harga grand total-->
        <Border Grid.Row="2" Padding="20,15,20,10" StrokeShape="RoundRectangle 20,20,0,0"  Stroke="Transparent" 
                StrokeThickness="0.5" BackgroundColor="White">
            <toolkit:Expander IsExpanded="False">
                <toolkit:Expander.Header>
                    <StackLayout Orientation="Horizontal">
                        <Label Text="Grand Total" HorizontalOptions="FillAndExpand" FontSize="Large" FontAttributes="Bold"  Padding="5"/>
                        <Image Source="chevron100.png" TranslationY="-3" HeightRequest="24"></Image>
                    </StackLayout>
                </toolkit:Expander.Header>
                <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,10,0,0" ColumnSpacing="10" RowSpacing="5" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                    
                    <!--subtotal-->
                    <Image Source="subtotal100grey.png" HeightRequest="16" Grid.Column="0" Grid.Row="0"></Image>
                    <Label Text="Subtotal" Grid.Column="1" Grid.Row="0" TextColor="#575757"></Label>
                    <Label Text="Rp 0" x:Name="EntrySubtotal" FontAttributes="Bold" HorizontalTextAlignment="End" Grid.Column="2" Grid.Row="0"></Label>

                    <!--diskon-->
                    <Image Source="diskon100.png" HeightRequest="16" Grid.Column="0" Grid.Row="1"></Image>
                    <Label Text="Diskon" Grid.Column="1" Grid.Row="1" TextColor="#575757"></Label>
                    <Label Text="Rp 0" x:Name="EntryTotalDiskon" FontAttributes="Bold" Grid.Column="2" Grid.Row="1" HorizontalTextAlignment="End"></Label>


                    <!--biaya-->
                    <Image Source="propertiesgrey100.png" HeightRequest="16" Grid.Column="0" Grid.Row="2"></Image>
                    <Label Text="Biaya Lain" Grid.Column="1" Grid.Row="2" TextColor="#575757"></Label>
                    <Label Text="Rp 0" x:Name="EntryTotalBiaya" FontAttributes="Bold" Grid.Column="2" Grid.Row="2" HorizontalTextAlignment="End"></Label>

                    <!--PPN11/12-->
                    <Image Source="tax100grey.png" HeightRequest="16" Grid.Column="0" Grid.Row="3"></Image>
                    <Label Text="PPN 11/12" Grid.Column="1" Grid.Row="3" TextColor="#575757"></Label>
                    <Label Text="Rp 0" x:Name="EntryTotalPajak" FontAttributes="Bold" Grid.Column="2" Grid.Row="3" HorizontalTextAlignment="End"></Label>
                    
                    <!--garis-->
                    <BoxView HeightRequest="1" Margin="0"  Color="LightGray" HorizontalOptions="Fill" Grid.Row="4" Grid.ColumnSpan="3"/>

                    <!--total harga-->
                    <Image Source="grandtotal100gray.png" HeightRequest="16" Grid.Column="0" Grid.Row="5"></Image>
                    <Label Text="Total Faktur" Grid.Column="1" Grid.Row="5" TextColor="#575757"></Label>
                    <Label Text="Rp 0" x:Name="EntryGrandTotal"  TextColor="DarkCyan" FontAttributes="Bold" Grid.Column="2" Grid.Row="5" HorizontalTextAlignment="End"></Label>
                    
                    <!--Bayar Pas, membulatkan--> 
                    <Image Source="paypas.png" HeightRequest="16" Grid.Column="0" Grid.Row="6"></Image>
                    <Label Text="Total Pembulatan" Grid.Column="1" Grid.Row="6" TextColor="#575757"></Label>
                    <Label Text="Rp 0" x:Name="EntryGrandTotalRounded" FontSize="20" TextColor="DarkGoldenrod" FontAttributes="Bold" Grid.Column="2" Grid.Row="6" HorizontalTextAlignment="End"></Label>

                </Grid>
                

            </toolkit:Expander>
        </Border>

        <!--row 3 tombol tombol-->
        <Grid ColumnDefinitions="0.25*,0.25*,0.25*,*" Grid.Row="3">
            <StackLayout BackgroundColor="OrangeRed" Grid.Column="0" VerticalOptions="Fill">
                <StackLayout.GestureRecognizers>
                    <TapGestureRecognizer x:Name="B_ShipmentTapGesture" Tapped="B_ShipmentTapGesture_Tapped"></TapGestureRecognizer>
                </StackLayout.GestureRecognizers>
                <Image Source="shipment.png" TranslationY="5" HeightRequest="32" VerticalOptions="Center"></Image>
            </StackLayout>

            <StackLayout BackgroundColor="DodgerBlue" Grid.Column="1">
                <StackLayout.GestureRecognizers>
                    <TapGestureRecognizer x:Name="B_BiayaTapGesture" Tapped="B_BiayaTapGesture_Tapped"></TapGestureRecognizer>
                </StackLayout.GestureRecognizers>
                <Image Source="propertieswhite100.png" TranslationY="5" HeightRequest="32" VerticalOptions="Center"></Image>
            </StackLayout>

            <StackLayout BackgroundColor="DeepPink" Grid.Column="2">
                <StackLayout.GestureRecognizers>
                    <TapGestureRecognizer x:Name="B_Diskon" Tapped="B_Diskon_Tapped"></TapGestureRecognizer>
                </StackLayout.GestureRecognizers>
                <Image Source="diskonwhite100.png" TranslationY="5" HeightRequest="32" VerticalOptions="Center"></Image>
            </StackLayout>

            <Button Grid.Row="2" CornerRadius="0" Grid.Column="3"
                FontSize="20" FontAttributes="Bold" x:Name="B_NewFaktur" Clicked="B_NewFaktur_Clicked"
                BackgroundColor="DarkCyan" ImageSource="add24.png" Text="BUAT FAKTUR"></Button>
        </Grid>
        
        
    </Grid>
</ContentPage>