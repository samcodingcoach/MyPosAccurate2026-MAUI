<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MyPosAccurate2026.Coa.Detail"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#f8fafa"
             >
    <Grid RowDefinitions="Auto,*">
        <!--search & sort-->
        <Border Grid.Row="0" x:Name="FormSearch" IsVisible="True" Padding="10" StrokeShape="RoundRectangle 10" Margin="10" Stroke="Transparent" StrokeThickness="0.5" BackgroundColor="White">
            <Border.Shadow>
                <Shadow Brush="#000000" Opacity="0.10" Radius="12" Offset="0,-3" />
            </Border.Shadow>
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                <Border Grid.Column="0" Padding="0" StrokeShape="RoundRectangle 10"  Stroke="#CCCCCC" StrokeThickness="0.5" BackgroundColor="White">
                    <SearchBar Placeholder="Kode Akun atau Nama" x:Name="T_Search" TextChanged="T_Search_TextChanged">
                    </SearchBar>
                </Border>
                <Border Grid.Column="1" Padding="10,0" StrokeShape="RoundRectangle 10"  Stroke="#CCCCCC" StrokeThickness="0.5" BackgroundColor="WhiteSmoke">
                    <Image Source="filtersort100" HeightRequest="24" Opacity="0.8">
                        <Image.GestureRecognizers>
                            <!--mengeluarkan action sheet memasukan tanggal format DD/MM/YYYY-->
                            <TapGestureRecognizer x:Name="TapAdd" Tapped="TapAdd_Tapped" />
                            
                        </Image.GestureRecognizers>
                    </Image>
                </Border>
            </Grid>
        </Border>
        
        <Grid RowDefinitions="Auto,*,Auto" Grid.Row="1">
            <!--total sum coa-->
            <Border Grid.Row="0" x:Name="FormTotal" IsVisible="True" Padding="20" StrokeShape="RoundRectangle 10" 
                    Margin="10,0,10,0" Stroke="Transparent" 
                    StrokeThickness="0.5" BackgroundColor="DarkCyan">
                <StackLayout Spacing="10">
                    <StackLayout Orientation="Horizontal" Spacing="5">
                        <Label Text="TOTAL ASET" TextColor="White" FontSize="Caption"></Label>
                        <Image Source="datewhite1.png" HeightRequest="14" HorizontalOptions="EndAndExpand"></Image>
                        <Label x:Name="LabelDate" Text="PER TANGGAL 02/07/2026" FontSize="Caption" VerticalTextAlignment="Center" TextColor="White"></Label>
                        
                    </StackLayout>
                    <Label x:Name="LabelTotalAset" Text="Rp 0" VerticalTextAlignment="Center" 
                           FontAttributes="Bold" FontSize="Large" 
                           TextColor="White"></Label>
                           
                    <StackLayout Orientation="Horizontal" Spacing="5" Margin="0,5,0,0">
                        <Label Text="SELISIH:" TextColor="LightGray" FontSize="Caption" VerticalTextAlignment="Center"></Label>
                        <Label x:Name="LabelSelisih" Text="Rp 0" TextColor="White" FontSize="Small" FontAttributes="Bold" VerticalTextAlignment="Center"></Label>
                    </StackLayout>
                </StackLayout>
                
            </Border>

            <RefreshView Grid.Row="1" x:Name="RV_Neraca" Refreshing="OnRefreshing" Margin="10,10,10,10">
                <CollectionView x:Name="CV_Neraca" IsGrouped="True">
                    <CollectionView.GroupHeaderTemplate>
                        <DataTemplate>
                            <StackLayout Margin="0,10,0,0">
                                <StackLayout Orientation="Horizontal">
                                    <Label Text="{Binding Name}" TextColor="{Binding TitleColor}" FontAttributes="Bold"></Label>
                                    <Border Padding="15,2" StrokeShape="RoundRectangle 10" 
                                            Stroke="Transparent" HorizontalOptions="EndAndExpand"
                                            StrokeThickness="0.5" BackgroundColor="#D4E6E5">
                                        <Label Text="{Binding TotalFormatted}" TextColor="#444" VerticalTextAlignment="Center" FontSize="Caption"></Label>
                                    </Border>
                                </StackLayout>
                              
                            </StackLayout>
                        </DataTemplate>
                    </CollectionView.GroupHeaderTemplate>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <!--sample ui juga buat RugiLaba-->
                            <Border Padding="0" StrokeShape="RoundRectangle 10" VerticalOptions="Start"
                                    Stroke="LightGray" StrokeThickness="1" BackgroundColor="Transparent" Margin="0,5,0,5">
                                    
                                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" BackgroundColor="Transparent">

                                    <!-- Parent (Level 1) Data -->
                                    <StackLayout Grid.Column="0" Grid.Row="0" Padding="20,20,20,10">
                                        <Label Text="{Binding accountName}" FontSize="18"></Label>
                                        <Label Text="{Binding accountNo}" TextColor="LightGrey" FontSize="Caption"></Label>
                                    </StackLayout>

                                    <StackLayout Grid.Column="1" Grid.Row="0" VerticalOptions="Center" Padding="20,20,20,10">
                                        <Label Text="{Binding amount_fmt}" FontSize="18" TextColor="#444" FontAttributes="Bold"></Label>
                                    </StackLayout>
                                    <BoxView HeightRequest="0.5" Opacity="1" Grid.Column="0" 
                                             Grid.ColumnSpan="2" Grid.Row="1" Color="LightGrey" 
                                             HorizontalOptions="Fill" ></BoxView>
                                             
                                    <!-- Children (Level 2) nested inside -->
                                    <StackLayout Grid.Row="2" Grid.ColumnSpan="2" BindableLayout.ItemsSource="{Binding Children}">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="12,0,0,0" ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" BackgroundColor="White">
                                                    <StackLayout Grid.Column="0" Grid.Row="0" Padding="20,20,20,10">
                                                        <Label Text="{Binding accountName}" FontSize="16"></Label>
                                                        <Label Text="{Binding accountNo}" TextColor="LightGrey" FontSize="Caption"></Label>
                                                    </StackLayout>

                                                    <StackLayout Grid.Column="1" Grid.Row="0" VerticalOptions="Center" Padding="20,20,20,10">
                                                        <Label Text="{Binding amount_fmt}" FontSize="16" TextColor="#444" FontAttributes="Bold"></Label>
                                                    </StackLayout>
                                                    <BoxView HeightRequest="0.5" Opacity="1" Grid.Column="0" 
                                                             Grid.ColumnSpan="2" Grid.Row="1" Color="LightGrey" 
                                                             HorizontalOptions="Fill" ></BoxView>
                                                </Grid>
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </StackLayout>

                                </Grid>
                                
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </RefreshView>
            
            <Grid Grid.Row="2" Padding="10,5,10,10">
                <Button x:Name="BtnDownloadPdf" Text="DOWNLOAD PDF"
                        CharacterSpacing="2" FontAttributes="Bold" BackgroundColor="#444"
                        Clicked="BtnDownloadPdf_Clicked"/>
            </Grid>
        </Grid>
        
    </Grid>
</ContentPage>