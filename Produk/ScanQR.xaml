<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MyPosAccurate2026.Produk.ScanQR" BackgroundColor="GhostWhite"
             NavigationPage.HasNavigationBar="False"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:zxing="clr-namespace:ZXing.Net.Maui.Controls;assembly=ZXing.Net.MAUI.Controls"
             Title="ScanQR">
    <Grid RowDefinitions="*,Auto" RowSpacing="0" ColumnDefinitions="*" ColumnSpacing="10" Padding="0">
        <!--Area Camera Aktif Scanner-->
        <Grid Grid.Row="0">
            <zxing:CameraBarcodeReaderView x:Name="CameraScanner" BarcodesDetected="CameraScanner_BarcodesDetected" />

            <!--Bingkai pemindaian-->
            <Border WidthRequest="240" HeightRequest="240" InputTransparent="True"
                    StrokeShape="RoundRectangle 20" Stroke="White" StrokeThickness="3"
                    BackgroundColor="Transparent" HorizontalOptions="Center" VerticalOptions="Center" />

            <Label Text="Arahkan kamera ke barcode / QR code produk" InputTransparent="True"
                   TextColor="White" FontAttributes="Bold" BackgroundColor="#80000000" Padding="16,8"
                   HorizontalOptions="Center" VerticalOptions="Start" Margin="0,30,0,0" />

            <ActivityIndicator x:Name="LoadingIndicator" IsRunning="False" IsVisible="False"
                               Color="White" HorizontalOptions="Center" VerticalOptions="Center" />
        </Grid>

        <Border Grid.Row="1" Padding="20,10" StrokeShape="RoundRectangle 20,20,0,0"  Stroke="Transparent" 
                StrokeThickness="0.5" BackgroundColor="White">
            <Border.Shadow>
                <Shadow Brush="#000000" Opacity="0.10" Radius="12" Offset="0,-3" />
            </Border.Shadow>
            <toolkit:Expander IsExpanded="False" x:Name="ExpanderResult">
                <toolkit:Expander.Header>
                    <Border Grid.Row="0" Padding="15,10" HorizontalOptions="Center" StrokeShape="RoundRectangle 10"  Stroke="Transparent" 
                                StrokeThickness="0.5" BackgroundColor="DarkCyan">
                        <Label Text="HASIL PEMINDAIAN" FontAttributes="Bold" HorizontalOptions="Center" TextColor="White"></Label>
                    </Border>
                </toolkit:Expander.Header>

                <Grid ColumnDefinitions="0.5*,0.5*" ColumnSpacing="10" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="10">

                    <Line X2="360"  Stroke="#CFCFCF" Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="2" StrokeThickness="1.4" StrokeDashArray="3,3"
                                HorizontalOptions="Fill" TranslationY="10"/>
                    <Grid Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="2" 
                          ColumnDefinitions="Auto,*" ColumnSpacing="10" Margin="0,10,0,0" RowDefinitions="Auto,Auto,Auto">
                        <Image Source="nophotoproduct150.jpg" x:Name="imageProduct" HeightRequest="80" Grid.Column="0" Grid.Row="0" Grid.RowSpan="3"></Image>
                        <Label Text=""   x:Name="nameProduct"
                               FontSize="18" MaxLines="2" LineBreakMode="TailTruncation" Grid.Column="1" Grid.Row="0" 
                               FontAttributes="Bold" TextColor="#444"></Label>
                        <Label Text="" x:Name="noitemProduct" Grid.Column="1" Grid.Row="1" TextColor="LightGrey"></Label>
                        <Label Text="" x:Name="priceProduct" Grid.Column="2" Grid.Row="2" 
                               FontAttributes="Bold" FontSize="18"
                               HorizontalOptions="End" TextColor="Goldenrod" HorizontalTextAlignment="End"></Label>
                    </Grid>
                    
                    
                    <Border Grid.Row="2" Grid.Column="0" Padding="20,10" StrokeShape="RoundRectangle 5" Margin="0,10,0,0"  Stroke="Grey" 
                         StrokeThickness="0.2" BackgroundColor="WhiteSmoke">
                        <StackLayout>

                            <Label Text="Stok tersedia" HorizontalOptions="End"></Label>
                            
                            <StackLayout Spacing="10" Orientation="Horizontal">
                                <Image Source="stok64green.png" TranslationY="-10" HeightRequest="32" VerticalOptions="Center"></Image>
                                <Label Text="0 Unit" x:Name="stokavailableProduct" HorizontalOptions="EndAndExpand" FontSize="Large" TextColor="Grey" FontAttributes="Bold" VerticalTextAlignment="Center" HorizontalTextAlignment="End"></Label>
                            </StackLayout> 
                        </StackLayout>
                    </Border>

                    <Border Grid.Row="2" Grid.Column="1" Padding="20,10" StrokeShape="RoundRectangle 5" Margin="0,10,0,0"  Stroke="Grey" 
                         StrokeThickness="0.2" BackgroundColor="WhiteSmoke">
                        <StackLayout>

                            <Label Text="Gudang" HorizontalOptions="End"></Label>
                            
                            <StackLayout Spacing="10" Orientation="Horizontal">
                                <Image Source="gudang100green.png" TranslationY="-10" HeightRequest="32" VerticalOptions="Center"></Image>
                                <Label Text="Gudang Utama" x:Name="warehouseProduct" MaxLines="1" LineBreakMode="HeadTruncation" HorizontalOptions="EndAndExpand" FontSize="Large" TextColor="Grey" FontAttributes="Bold" VerticalTextAlignment="Center" HorizontalTextAlignment="End"></Label>
                            </StackLayout> 
                        </StackLayout>
                    </Border>


                    <Button x:Name="BDetail" Clicked="BDetail_Clicked" CornerRadius="10" Margin="0,10,0,0" Grid.Column="0" Grid.Row="3" FontSize="17" Text="Detail Produk" BackgroundColor="DarkCyan" TextColor="White" FontAttributes="Bold"></Button>
                    <Button CornerRadius="10" x:Name="BScanAgain" Clicked="BScanAgain_Clicked" Margin="0,10,0,0" Grid.Column="1" Grid.Row="3" FontSize="17" Text="Scan Lagi" BorderColor="DarkCyan" BorderWidth="1" BackgroundColor="Transparent" TextColor="DarkCyan" FontAttributes="Bold"></Button>
                </Grid>

            </toolkit:Expander>
        </Border>

    </Grid>
</ContentPage>