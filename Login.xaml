<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MyPosAccurate2026.Login" 
             BackgroundColor="#F7F9FC" 
             NavigationPage.HasNavigationBar="False"
             Title="Login">

    <ScrollView>
        <VerticalStackLayout Padding="30,50,30,30" Spacing="25" VerticalOptions="CenterAndExpand">
            
            <!-- Logo or Title Area -->
            <VerticalStackLayout Spacing="5" HorizontalOptions="Center" Margin="0,40,0,30">
                <Label Text="POS ACCURATE" 
                       FontSize="32"
                       FontAttributes="Bold" 
                       TextColor="#2C3E50"
                       HorizontalOptions="Center" />
                <Label Text="Silakan login ke akun Anda"
                       FontSize="14"
                       TextColor="#7F8C8D"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>

            <!-- Input Form -->
            <VerticalStackLayout Spacing="20">
                
                <!-- Email Entry -->
                <Frame Padding="15,0" CornerRadius="12" BackgroundColor="White" HasShadow="False" BorderColor="#E0E0E0" HeightRequest="55">
                    <Entry x:Name="EmailEntry" 
                           Placeholder="Alamat Email" 
                           Keyboard="Email" 
                           PlaceholderColor="#A0A0A0"
                           TextColor="#333333"
                           ReturnType="Next" 
                           VerticalOptions="Center" />
                </Frame>

                <!-- Password Entry with Toggle -->
                <Frame Padding="15,0" CornerRadius="12" BackgroundColor="White" HasShadow="False" BorderColor="#E0E0E0" HeightRequest="55">
                    <Grid ColumnDefinitions="*, Auto">
                        <Entry x:Name="PasswordEntry" 
                               Placeholder="Password" 
                               IsPassword="True" 
                               PlaceholderColor="#A0A0A0"
                               TextColor="#333333"
                               ReturnType="Done" 
                               VerticalOptions="Center" />
                               
                        <Button x:Name="TogglePasswordBtn" 
                                Text="Show" 
                                Grid.Column="1" 
                                BackgroundColor="Transparent" 
                                TextColor="#3498DB" 
                                FontSize="14"
                                FontAttributes="Bold"
                                Padding="10,0"
                                Clicked="TogglePasswordBtn_Clicked"
                                VerticalOptions="Center" />
                    </Grid>
                </Frame>

                <!-- Remember Me Checkbox -->
                <HorizontalStackLayout Spacing="10" VerticalOptions="Center" Margin="0,5,0,10">
                    <CheckBox x:Name="RememberMeCheckBox" Color="DarkCyan" VerticalOptions="Center" />
                    <Label Text="Ingat Saya" TextColor="#7F8C8D" FontSize="14" VerticalOptions="Center" VerticalTextAlignment="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="RememberMeLabel_Tapped" />
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>
            </VerticalStackLayout>

            <!-- Login Button -->
            <Button x:Name="B_Login" 
                    Clicked="B_Login_Clicked"
                    Text="LOGIN" 
                    FontAttributes="Bold"
                    FontSize="16"
                    TextColor="White"
                    BackgroundColor="DarkCyan"
                    CornerRadius="12" 
                    HeightRequest="55"
                    Margin="0,10,0,0"/>
            
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>