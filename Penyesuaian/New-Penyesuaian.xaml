<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MyPosAccurate2026.Penyesuaian.New_Penyesuaian"
             NavigationPage.HasNavigationBar="False"
            >

    <Grid RowDefinitions="Auto,*,Auto,Auto" Padding="10">

        <StackLayout Spacing="5">

            <Border Padding="10,2" StrokeShape="RoundRectangle 10" Stroke="#CCCCCC" StrokeThickness="0.5" BackgroundColor="Transparent">

                <StackLayout Orientation="Horizontal">
                    <DatePicker Format="dd/MM/yyyy"></DatePicker>
                    <Image HorizontalOptions="EndAndExpand" Source="date100.png" HeightRequest="24" Opacity="0.5"></Image>
                </StackLayout>

            </Border>

            <Border Padding="0,2,10,2" StrokeShape="RoundRectangle 10" Stroke="#CCCCCC" StrokeThickness="0.5" BackgroundColor="Transparent">

                <SearchBar Placeholder="Ketik Nama atau Kode Barang..." x:Name="SearchBar_Item" SearchIconColor="DarkCyan"
                     HorizontalOptions="FillAndExpand"/>

            </Border>

            <StackLayout Orientation="Horizontal" Padding="10">
                <Label Text="Detail Barang Penyesuaian" FontSize="20" FontAttributes="Bold" TextColor="#444"></Label>
                <Label Text="100 Items" FontSize="Caption" TextColor="Grey" HorizontalOptions="EndAndExpand" 
                 VerticalTextAlignment="Center"></Label>
            </StackLayout>



           

           
        </StackLayout>

        <!--data barang terselect-->
        <Border VerticalOptions="Start" Grid.Row="1" Padding="10" StrokeShape="RoundRectangle 10" Margin="0" Stroke="Transparent" 
                StrokeThickness="0.5" BackgroundColor="White">
            <Border.Shadow>
                <Shadow Brush="#000000" Opacity="0.15" Radius="5" Offset="0,1" />
            </Border.Shadow>

            <Grid ColumnDefinitions="Auto, *" ColumnSpacing="15">

                <Image Source="pp100.jpg"  Grid.Column="0" HeightRequest="75" WidthRequest="75" Aspect="AspectFill" VerticalOptions="Start"></Image>

                <StackLayout Grid.Column="1" Spacing="2">

                    <Grid ColumnDefinitions="*, Auto">
                        <Label Grid.Column="0" Text="NAMA BARANG YANG DIMUAT DAN DISESUAIKAN DLL" 
                        FontAttributes="Bold" TextColor="#444" FontSize="14" MaxLines="2" 
                        LineBreakMode="TailTruncation" VerticalOptions="Start" />

                        <Image Source="delete1.png" HeightRequest="20" HorizontalOptions="EndAndExpand">
                            <Image.GestureRecognizers>
                                <TapGestureRecognizer />
                            </Image.GestureRecognizers>
                        </Image>

                    </Grid>

                    <Label Text="No. 100015" TextColor="DarkCyan" FontSize="Caption" />

                    <Label Text="STOK IN : 10" TextColor="Black" TranslationY="5" FontSize="13" />



                    <Grid ColumnDefinitions="*, Auto" Margin="0,3,0,0">

                        <Label Grid.Column="1" Text="Rp 10.000.000" FontAttributes="Bold" TextColor="DarkCyan" FontSize="18" VerticalOptions="Center" HorizontalOptions="End" />
                    </Grid>



                </StackLayout>
            </Grid>


        </Border>

        <StackLayout Grid.Row="2" Spacing="5" Margin="0,0,0,10">
            <Border Padding="10,2" StrokeShape="RoundRectangle 10" Stroke="#CCCCCC" StrokeThickness="0.5" BackgroundColor="Transparent">
                <StackLayout Orientation="Horizontal">
                    <Picker Title="Pilih Akun Prakiraan Penyesuaian"></Picker>
                    <Image Source="chevron100.png" Opacity="0.5" HeightRequest="24" HorizontalOptions="EndAndExpand"></Image>
                </StackLayout>
            </Border>
            <Border Padding="10,2" StrokeShape="RoundRectangle 10" Stroke="#CCCCCC" StrokeThickness="0.5" BackgroundColor="Transparent">
                <Editor Placeholder="Keterangan (Opsional)" HeightRequest="60"></Editor>
            </Border>
        </StackLayout>
        

        <Grid ColumnDefinitions="0.3*,0.7*" ColumnSpacing="10" Grid.Row="3">
            <Button Text="BATAL" FontAttributes="Bold" FontSize="18" TextColor="LightGray" BackgroundColor="Transparent" BorderWidth="0.5" BorderColor="LightGray"></Button>
            <Button Text="SIMPAN" FontAttributes="Bold" Grid.Column="1" FontSize="18" BackgroundColor="DarkCyan"></Button>
        </Grid>
    </Grid>
  
</ContentPage>